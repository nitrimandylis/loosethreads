# --- Required ---
DATABASE_URL=                      # Neon Postgres connection string
ADMIN_SECRET=                      # password for /admin (min 8 chars; use something long)

# --- Recommended in production (app degrades gracefully without them) ---
UPSTASH_REDIS_REST_URL=            # per-IP rate limit (no limit if unset)
UPSTASH_REDIS_REST_TOKEN=
TURNSTILE_SECRET_KEY=              # Cloudflare Turnstile (no bot check if unset)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NVIDIA_NIM_API_KEY=                # NVIDIA NIM key from build.nvidia.com (manual-review fallback if unset)
NVIDIA_NIM_BASE_URL=               # optional: self-hosted NIM /v1 URL (defaults to hosted integrate.api.nvidia.com)
MOD_MODEL=meta/llama-3.1-8b-instruct  # optional: NIM triage model (must support structured output)
