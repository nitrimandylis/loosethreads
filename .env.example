# --- Required ---
DATABASE_URL=                      # Neon Postgres connection string
ADMIN_SECRET=                      # password for the /admin moderation queue

# --- Recommended in production (app degrades gracefully without them) ---
UPSTASH_REDIS_REST_URL=            # per-IP rate limit (no limit if unset)
UPSTASH_REDIS_REST_TOKEN=
TURNSTILE_SECRET_KEY=              # Cloudflare Turnstile (no bot check if unset)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
AI_GATEWAY_API_KEY=                # Vercel AI Gateway (manual-review fallback if unset)
MOD_MODEL=openai/gpt-4o-mini       # optional: triage model via the gateway
